# AI Providers (optional — presets work without these)
# Required only for: custom resolution drafting, LLM-augmented predictions
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_GENERATIVE_AI_API_KEY=...
AI_PROVIDER=claude

# Neo4j Aura (optional — enhances KG with persistence + Cypher queries)
# Free tier: https://neo4j.com/cloud/aura-free/
# When set, enables: user sandbox mutations, full 870K vote edge traversal,
# community detection, and persistent ontology modifications
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=...
